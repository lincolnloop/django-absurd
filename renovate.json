{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["helpers:pinGitHubActionDigests", ":configMigration"],
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "dependencyDashboard": true,
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,
  "minimumReleaseAge": "7 days",
  "rangeStrategy": "update-lockfile",
  "lockFileMaintenance": {
    "enabled": true,
    "dependencyDashboardApproval": true,
    "schedule": ["at any time"]
  },
  "poetry": {
    "enabled": false
  },
  "pre-commit": {
    "enabled": true
  },
  "prConcurrentLimit": 1,
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "description": "Hard-pin build backend + dev deps to exact versions.",
      "matchDepTypes": ["build-system.requires", "dependency-groups"],
      "rangeStrategy": "pin",
      "groupName": "dev dependencies"
    },
    {
      "matchPackageNames": ["hatch*"],
      "groupName": "hatch"
    },
    {
      "matchPackageNames": ["pytest", "pytest-*", "django-coverage-plugin"],
      "groupName": "pytest"
    },
    {
      "matchPackageNames": ["mypy", "django-stubs"],
      "groupName": "type checking"
    },
    {
      "matchPackageNames": ["python"],
      "groupName": "python"
    },
    {
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit hooks"
    },
    {
      "matchUpdateTypes": ["lockFileMaintenance"],
      "prPriority": -1
    }
  ]
}
