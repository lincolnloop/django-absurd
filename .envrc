# Reserve a host Postgres port for this project so `docker compose up -d db` and the test
# suite never collide with other local projects on 5432. One knob: drives both the compose
# host-port mapping and Django's connection (tests/settings.py reads PGPORT).
export PGPORT=5433

# Activate the uv-managed venv on cd (created by `uv sync`).
[ -d .venv ] && source .venv/bin/activate
