# Reserve host Postgres ports for this project so `docker compose up -d db db_pg_cron` and
# the test suites never collide with other local projects on 5432/5434.
export PGPORT=5433
# Host port for the pg_cron test server; tests/pg_cron/settings.py reads it.
export PGPORT_PGCRON=5434

# Activate the uv-managed venv on cd (created by `uv sync`).
[ -d .venv ] && source .venv/bin/activate
